#!/bin/sh /etc/rc.common
START=99
USE_PROCD=1

# 单实例锁文件
LOCK_FILE="/var/run/nutstore-guard.lock"

start_service() {
    # 单实例校验，避免重复启动
    if [ -f "$LOCK_FILE" ] && kill -0 $(cat "$LOCK_FILE") 2>/dev/null; then
        echo "守护进程已在运行，无需重复启动"
        return 0
    fi

    procd_open_instance
    procd_set_param command /bin/sh -c "echo \$\$ > $LOCK_FILE; while true; do /usr/bin/nutstore-adblock.sh guard; /usr/bin/nutstore-parent.sh guard; sleep 60; done"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    # 停止进程，清理锁文件
    killall -9 nutstore-adblock.sh nutstore-parent.sh 2>/dev/null || true
    rm -f "$LOCK_FILE" 2>/dev/null || true
}

enable() {
    local default_enabled=$(uci get nutstore_backup.global.guard_enable 2>/dev/null)
    if [ "$default_enabled" != "0" ]; then
        ln -s /etc/init.d/nutstore-optimize-guard /etc/rc.d/S99_nutstore-optimize-guard 2>/dev/null || true
    fi
}

disable() {
    rm -f /etc/rc.d/S99_nutstore-optimize-guard 2>/dev/null || true
}
