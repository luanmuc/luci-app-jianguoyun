config nutstore_backup 'global'
    option version 'V1.2.4_FULL_SYNC'
    option menu_level 'root'
    option enable_menu '1'
    option guard_enable '1'

config device_optimize 'device_optimize'
    option auto_detect '0'
    option hw_accel '1'
    option fw_freeze '0'

config tools 'tools'
    option scene_mode 'home'
    option bbr_enable '1'
    option cubic_enable '0'

config adblock 'adblock'
    option enable '0'
    option rule_mode 'home'
    option auto_update '0'
    option rule_url ''

config parent 'parent'
    option enable '0'
    option control_mode 'holiday'
    option temp_pass '0'
    option admin_ip ''
    option weekday_time '19:00-21:00'
    option weekend_time '14:00-18:00'
