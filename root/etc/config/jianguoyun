config global 'settings'
    option webdav_url ''
    option webdav_username ''
    option webdav_password ''
    option backup_path '/tmp/upload'
    option auto_cycle '7'
    option keep_count '30'
    option timeout '30'
    option retry_count '3'
    option main_version '0'

config backup 'auto'
    option daily_enable '1'
    option daily_keep_days '30'
    option monthly_light_enable '1'
    option monthly_full_enable '0'
    option monthly_keep_count '12'

config backup_content
    option light_backup_paths '/etc/config /etc/opkg/keys /usr/lib/opkg/status'
    option full_backup_extra '/usr/lib/lua/luci/model/cbi/jianguoyun /usr/lib/lua/luci/controller/jianguoyun /usr/bin/jianguoyun-backup.sh /etc/config/jianguoyun /etc/uci-defaults/99_luci-app-jianguoyun'
