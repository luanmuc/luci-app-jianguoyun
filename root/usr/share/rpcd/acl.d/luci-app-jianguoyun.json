{
    "luci-app-jianguoyun": {
        "description": "坚果云备份中心插件全功能权限",
        "read": {
            "uci": [ "nutstore_backup" ],
            "file": {
                "/tmp/nutstore_*.log": [ "read" ],
                "/tmp/speedtest_*.log": [ "read" ],
                "/tmp/conflict_check.log": [ "read" ]
            }
        },
        "write": {
            "uci": [ "nutstore_backup" ],
            "file": {
                "/usr/bin/nutstore-*.sh": [ "exec" ],
                "/etc/init.d/nutstore-optimize-guard": [ "exec", "enable", "disable", "start", "stop", "restart" ],
                "/tmp/nutstore_*.log": [ "write" ]
            }
        }
    }
}
