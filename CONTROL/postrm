#!/bin/sh
set -euo pipefail

# 开发文档：卸载后全量清理残留，不污染系统
rm -rf /usr/bin/jianguoyun-*.sh 2>/dev/null || true
rm -rf /usr/share/jianguoyun 2>/dev/null || true
rm -rf /etc/config/jianguoyun 2>/dev/null || true
rm -rf /etc/init.d/jianguoyun 2>/dev/null || true
rm -rf /etc/uci-defaults/99_luci-app-jianguoyun 2>/dev/null || true
rm -rf /usr/lib/lua/luci/controller/jianguoyun.lua 2>/dev/null || true
rm -rf /usr/lib/lua/luci/model/cbi/jianguoyun 2>/dev/null || true
rm -rf /usr/lib/lua/luci/view/jianguoyun 2>/dev/null || true
rm -rf /tmp/jianguoyun* 2>/dev/null || true

# 重启Luci生效
/etc/init.d/uhttpd reload 2>/dev/null || true

echo "✅ 坚果云备份插件已完全卸载"
exit 0
